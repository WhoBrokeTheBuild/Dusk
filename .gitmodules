	path = depend/glm
	url = https://github.com/g-truc/glm.git
	branch = 0.9.8
[submodule "depend/json"]
	path = depend/json
	url = https://github.com/nlohmann/json.git
	branch = master
[submodule "depend/zlib"]
	path = depend/zlib
	url = https://github.com/madler/zlib
	branch = tags/v1.2.11
[submodule "depend/flatbuffers"]
	path = depend/flatbuffers
	url = https://github.com/WhoBrokeTheBuild/flatbuffers.git
	branch = master
[submodule "depend/openal"]
	path = depend/openal
	url = https://github.com/kcat/openal-soft
	branch = master
[submodule "depend/ogg"]
	path = depend/libogg
	url = https://github.com/xiph/ogg
	branch = tags/v1.3.2
[submodule "depend/SDL2"]
	path = depend/SDL2
	url = https://github.com/spurious/SDL-mirror.git
