GET_FILENAME_COMPONENT(Dusk_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
include(CMakeFindDependencyMacro)

LIST(APPEND CMAKE_MODULE_PATH ${Dusk_CMAKE_DIR})

FIND_DEPENDENCY(GLM REQUIRED)
FIND_DEPENDENCY(JSON REQUIRED)
FIND_DEPENDENCY(SDL2 REQUIRED)
FIND_DEPENDENCY(Assimp REQUIRED)

LIST(REMOVE_AT CMAKE_MODULE_PATH -1)

IF(NOT TARGET Dusk::Dusk)
    INCLUDE("${Dusk_CMAKE_DIR}/DuskTargets.cmake")
ENDIF()

SET(Dusk_LIBRARIES Dusk::Dusk)