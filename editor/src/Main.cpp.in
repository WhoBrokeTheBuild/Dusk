#include <Main.hpp>
#include <Editor.hpp>
#include <cstdio>

const std::string PROJECT_FILENAME = "@CMAKE_SOURCE_DIR@/@PROJECT_NAME@.duskproj";

int main(int argc, char** argv) {
    Editor app(argc, argv);

    auto cb = app.OnLoadConfig.AddStatic([&](std::string) {
        _DuskSetup(&app);
    });
    app.LoadConfig(PROJECT_FILENAME);

    app.Start();
    return 0;
}
