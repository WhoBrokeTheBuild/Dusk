#include <dusk/Main.hpp>

const std::string PROJECT_FILENAME = "@_PROJECT_FILENAME@";

int main(int argc, char** argv) {
    dusk::App app(argc, argv);

    auto cb = app.OnLoadConfig.AddStatic([&](std::string) {
        _DuskSetup(&app);
    });
    app.LoadConfig(PROJECT_FILENAME);

    app.Start();
    return 0;
}
